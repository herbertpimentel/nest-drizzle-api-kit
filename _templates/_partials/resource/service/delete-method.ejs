<% } %><% } else if (transactional) { %><% if (validationExpression) { %>    const input = validateResourceInput(<%= validationExpression %>, { params: { id } });
    return this.db.transaction(async (tx) => {
      await tx.delete(<%= table %>).where(eq(<%= table %>.<%= idFieldName %>, input.params.id));
