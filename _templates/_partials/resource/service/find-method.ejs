  async find(query: <%= queryType %>): Promise<<%- returnType %>> {
<% if (hasHooks) { %><% if (validationExpression) { %>    const validatedQuery = validateResourceInput(<%= validationExpression %>, query);
<% } else { %>    const input = query;
<% } %>    const context = {
      db: this.db,
      resourceName: '<%= resourceName %>',
      functionName: 'find' as const,
      state: new Map<string, unknown>(),
      input: <%= validationExpression ? 'validatedQuery' : 'input' %>,
      result: undefined as <%- returnType %> | undefined,
    };

<% for (const line of beforeHookLines) { %><%= line %>
<% } %>    context.result = await new <%= queryClass %>(this.db).findMany(context.input);
<% for (const line of afterHookLines) { %><%= line %>
<% } %>    return context.result as <%- returnType %>;
<% } else if (validationExpression) { %>    const validatedQuery = validateResourceInput(<%= validationExpression %>, query);
    return new <%= queryClass %>(this.db).findMany(validatedQuery);
<% } else { %>    return new <%= queryClass %>(this.db).findMany(query);
<% } %>  }
