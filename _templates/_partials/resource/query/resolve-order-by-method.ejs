  private resolveOrderBy(fieldName: string, isDesc: boolean) {
    switch (fieldName) {
<% for (const sort of sorts) { %>      case '<%= sort.field %>':
        return isDesc ? desc(<%= tableAccessExpression %>.<%= sort.field %>) : asc(<%= tableAccessExpression %>.<%= sort.field %>);
<% } %>      default:
        return null;
    }
  }
