  protected resolveCondition(filter: ParsedFilter) {
    switch (filter.field) {
<% for (const filter of filters) { %>      case '<%= filter.field %>':
        return buildAllowedColumnCondition(
          <%= tableAccessExpression %>.<%= filter.field %>,
          filter.operator,
          filter.value,
          <%- JSON.stringify(filter.operators) %> as const,
        );
<% } %>      default:
        return null;
    }
  }
